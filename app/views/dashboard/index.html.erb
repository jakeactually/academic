<% content_for :title, "Dashboard" %>

<h1 class="h3 mb-4">Dashboard</h1>

<p class="mb-4">You are signed in as <strong><%= current_user.email %></strong>. Role: <span class="badge <%= bootstrap_role_badge_class(current_user.role) %>"><%= current_user.role.humanize %></span></p>

<% if current_user.admin? %>
  <div class="card mb-4 border-primary shadow-sm">
    <div class="card-header bg-primary-subtle">
      <strong>Core Catalog (Seeded)</strong>
    </div>
    <div class="list-group list-group-flush">
      <%= link_to "Careers", admin_careers_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Teachers", admin_teachers_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Students", admin_students_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Subjects", admin_subjects_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Classrooms", admin_classrooms_path, class: "list-group-item list-group-item-action" %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header">
      Other Resources
    </div>
    <div class="list-group list-group-flush">
      <%= link_to "Career Subjects", admin_career_subjects_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Teacher Subjects", admin_teacher_subjects_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Subject Dependencies", admin_dependent_subjects_path, class: "list-group-item list-group-item-action" %>
      <%= link_to "Classes", admin_course_classes_path, class: "list-group-item list-group-item-action" %>
    </div>
  </div>
<% elsif current_user.teacher? %>
  <% if @teacher.nil? %>
    <div class="alert alert-warning">
      We couldn't find a teacher record matching your email (<strong><%= current_user.email %></strong>). Please contact administration.
    </div>
  <% else %>
    <div class="card mb-4 border-success shadow-sm">
      <div class="card-header bg-success text-white">
        <strong>Teacher Information</strong>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <strong>Name:</strong> <%= @teacher.name %>
          </div>
        </div>
      </div>
    </div>

    <h2 class="h5 mb-3">My Schedule</h2>
    <% if @assigned_classes.any? %>
      <%= render "schedule_grid", schedule_classes: @schedule_classes, role: :teacher %>
    <% else %>
      <div class="alert alert-info">You do not have any assigned classes yet.</div>
    <% end %>
  <% end %>

<% elsif current_user.student? %>
  <% if @student.nil? %>
    <div class="alert alert-warning">
      We couldn't find a student record matching your email (<strong><%= current_user.email %></strong>). Please contact administration.
    </div>
  <% else %>
    <div class="card mb-4 border-info shadow-sm">
      <div class="card-header bg-info text-white">
        <strong>Student Information</strong>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4">
            <strong>Name:</strong> <%= @student.name %>
          </div>
          <div class="col-md-4">
            <strong>Career:</strong> <%= @student.career.name %>
          </div>
          <div class="col-md-4">
            <strong>Semester:</strong> <%= @student.semester %>
          </div>
        </div>
      </div>
    </div>

    <h2 class="h5 mb-3">My Schedule</h2>
    <% if @taken_classes.any? %>
      <%= render "schedule_grid", schedule_classes: @schedule_classes, role: :student %>
    <% else %>
      <div class="alert alert-info">You are not enrolled in any classes yet.</div>
    <% end %>

    <h2 class="h5 mb-3 mt-5">Available Classes (Semester <%= @student.semester %>)</h2>
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Subject</th>
                <th>Teacher</th>
                <th>Classroom</th>
                <th>Time (Day/Hour)</th>
                <th class="text-end pe-4">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @available_classes.any? %>
                <% @available_classes.each do |c| %>
                  <tr>
                    <td class="ps-4"><%= c.teacher_subject.subject.name %></td>
                    <td><%= c.teacher_subject.teacher.name %></td>
                    <td><%= c.classroom.name %></td>
                    <td><%= c.weekday %> / <%= c.dayhour %></td>
                    <td class="text-end pe-4">
                      <%= button_to "Enroll", enroll_class_path(c), method: :post, class: "btn btn-sm btn-primary" %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">No more available classes for your semester.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
