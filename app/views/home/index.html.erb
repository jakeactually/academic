<% content_for :title, "Home" %>

<div class="dashboard">
  <h1>Welcome</h1>
  <p>You are signed in as <strong><%= current_user.email %></strong>.</p>
  <p>Role: <strong class="role role--<%= current_user.role %>"><%= current_user.role.humanize %></strong></p>

  <p class="dashboard__next">Use this page as a starting point for role-specific dashboards (admin, teacher, student).</p>

  <%= button_to "Sign out", logout_path, method: :delete, class: "button--secondary" %>
</div>
