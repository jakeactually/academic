<% content_for :title, "Subjects" %>

<h1 class="h3 mb-4">Subjects</h1>
<p><%= link_to "Back to Admin", admin_root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="h5">Create Subject</h2>
    <%= form_with url: admin_subjects_path, scope: :subject do |f| %>
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>
      <%= f.submit "Create Subject", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white py-3 border-bottom">
    <h2 class="h5 mb-0">List</h2>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Name</th>
            <th class="text-end pe-4">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if @subjects.any? %>
            <% @subjects.each do |subject| %>
              <tr>
                <td class="ps-4 fw-bold"><%= subject.name %></td>
                <td class="text-end pe-4">
                  <%= button_to "Delete", admin_subject_path(subject, page: params[:page]), method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Are you sure?" } %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="2" class="text-center p-4 text-muted">No subjects found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% if @subjects.any? %>
  <div class="d-flex justify-content-center mt-3">
    <%= paginate @subjects %>
  </div>
<% end %>
