<% content_for :title, "Subjects" %>

<h1 class="h3 mb-4">Subjects</h1>
<p><%= link_to "Back to Admin", admin_root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="h5">Create Subject</h2>
    <%= form_with url: admin_subjects_path, scope: :subject do |f| %>
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>
      <%= f.submit "Create Subject", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h2 class="h5">List</h2>
    <ul class="mb-0">
      <% @subjects.each do |subject| %>
        <li class="d-flex justify-content-between align-items-center gap-2">
          <span><%= subject.name %></span>
          <%= button_to "Delete", admin_subject_path(subject), method: :delete, class: "btn btn-outline-danger btn-sm" %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
