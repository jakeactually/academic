<% content_for :title, "Admin Catalog" %>

<h1 class="h3 mb-4">Admin Creation Panel</h1>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Career</h2>
        <%= form_with url: admin_careers_path, scope: :career do |f| %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <%= f.submit "Create Career", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Career Semester</h2>
        <%= form_with url: admin_career_semesters_path, scope: :career_semester do |f| %>
          <div class="mb-3">
            <%= f.label :career_id, "Career", class: "form-label" %>
            <%= f.collection_select :career_id, @careers, :id, :name, { prompt: "Select career" }, { class: "form-select", required: true } %>
          </div>
          <div class="mb-3">
            <%= f.label :name, "Semester", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true, placeholder: "Semester 1" %>
          </div>
          <%= f.submit "Create Semester", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Subject</h2>
        <%= form_with url: admin_subjects_path, scope: :subject do |f| %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <%= f.submit "Create Subject", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Teacher</h2>
        <%= form_with url: admin_teachers_path, scope: :teacher do |f| %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true %>
          </div>
          <%= f.submit "Create Teacher", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Classroom</h2>
        <%= form_with url: admin_classrooms_path, scope: :classroom do |f| %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <%= f.submit "Create Classroom", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Classroom Hour Slot</h2>
        <%= form_with url: admin_classroom_hour_slots_path, scope: :classroom_hour_slot do |f| %>
          <div class="mb-3">
            <%= f.label :classroom_id, "Classroom", class: "form-label" %>
            <%= f.collection_select :classroom_id, @classrooms, :id, :name, { prompt: "Select classroom" }, { class: "form-select", required: true } %>
          </div>
          <div class="mb-3">
            <%= f.label :label, "Hour Slot", class: "form-label" %>
            <%= f.text_field :label, class: "form-control", required: true, placeholder: "Mon 08:00-09:00" %>
          </div>
          <%= f.submit "Create Hour Slot", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Assign Subject to Career Semester</h2>
        <%= form_with url: admin_career_semester_subjects_path, scope: :career_semester_subject do |f| %>
          <div class="mb-3">
            <%= f.label :career_semester_id, "Career Semester", class: "form-label" %>
            <%= f.collection_select :career_semester_id, @career_semesters, :id, ->(cs) { "#{cs.career.name} - #{cs.name}" }, { prompt: "Select semester" }, { class: "form-select", required: true } %>
          </div>
          <div class="mb-3">
            <%= f.label :subject_id, "Subject", class: "form-label" %>
            <%= f.collection_select :subject_id, @subjects, :id, :name, { prompt: "Select subject" }, { class: "form-select", required: true } %>
          </div>
          <%= f.submit "Assign Subject", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Subject Dependency</h2>
        <%= form_with url: admin_dependent_subjects_path, scope: :dependent_subject do |f| %>
          <div class="mb-3">
            <%= f.label :subject_id, "Subject", class: "form-label" %>
            <%= f.collection_select :subject_id, @subjects, :id, :name, { prompt: "Select subject" }, { class: "form-select", required: true } %>
          </div>
          <div class="mb-3">
            <%= f.label :dependent_subject_id, "Depends on subject", class: "form-label" %>
            <%= f.collection_select :dependent_subject_id, @subjects, :id, :name, { prompt: "Select required subject" }, { class: "form-select", required: true } %>
          </div>
          <%= f.submit "Create Dependency", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Create Class</h2>
        <%= form_with url: admin_course_classes_path, scope: :course_class do |f| %>
          <div class="row">
            <div class="col-md-4 mb-3">
              <%= f.label :teacher_id, "Teacher", class: "form-label" %>
              <%= f.collection_select :teacher_id, @teachers, :id, :name, { prompt: "Select teacher" }, { class: "form-select", required: true } %>
            </div>
            <div class="col-md-4 mb-3">
              <%= f.label :subject_id, "Subject", class: "form-label" %>
              <%= f.collection_select :subject_id, @subjects, :id, :name, { prompt: "Select subject" }, { class: "form-select", required: true } %>
            </div>
            <div class="col-md-12 mb-3">
              <%= f.label :classroom_hour_slot_ids, "Classroom hour slots", class: "form-label d-block" %>
              <% @classroom_hour_slots.each do |slot| %>
                <div class="form-check">
                  <%= check_box_tag "course_class[classroom_hour_slot_ids][]", slot.id, false, id: "course_class_slot_#{slot.id}", class: "form-check-input" %>
                  <%= label_tag "course_class_slot_#{slot.id}", "#{slot.classroom.name} - #{slot.label}", class: "form-check-label" %>
                </div>
              <% end %>
            </div>
          </div>
          <%= f.submit "Create Class", class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-1">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Current Subject Dependencies</h2>
        <ul class="mb-0">
          <% @dependent_subjects.each do |dependency| %>
            <li><%= dependency.subject.name %> depends on <%= dependency.dependent_subject.name %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card">
      <div class="card-body">
        <h2 class="h5">Current Classes</h2>
        <ul class="mb-0">
          <% @course_classes.each do |course_class| %>
            <li>
              <strong><%= course_class.subject.name %></strong> - <%= course_class.teacher.name %>
              <% if course_class.classroom_hour_slots.any? %>
                (<%= course_class.classroom_hour_slots.map { |s| "#{s.classroom.name} #{s.label}" }.join(", ") %>)
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
