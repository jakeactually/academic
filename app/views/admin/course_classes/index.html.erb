<% content_for :title, "Classes" %>

<h1 class="h3 mb-4">
  Classes 
  <span class="badge bg-info text-dark ms-2" style="font-size: 0.5em; vertical-align: middle;">
    <%= @season.capitalize %> Season (<%= @season == 'summer' ? 'Odd' : 'Even' %> Semesters)
  </span>
</h1>
<p><%= link_to "Back to Dashboard", root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<% 
  career_palette = {
    "Business Management" => "#4e73df",
    "Computer Science" => "#1cc88a",
    "Economics" => "#e74a3b",
    "Finance" => "#f6c23e",
    "Graphic Design" => "#6f42c1",
    "Marketing" => "#36b9cc"
  }
  default_color = "#858796"
%>

<div class="mb-4">
  <h6 class="text-muted small text-uppercase fw-bold mb-2">Careers Legend</h6>
  <div class="d-flex flex-wrap gap-2">
    <% @careers.each do |career| %>
      <div class="d-flex align-items-center">
        <span class="badge me-1" style="width: 12px; height: 12px; background-color: <%= career_palette[career.name] || default_color %>; padding: 0;">&nbsp;</span>
        <small><%= career.name %></small>
      </div>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: admin_course_classes_path, method: :get, local: true do |f| %>
      <div class="row align-items-end">
        <div class="col-md-6 mb-3">
          <%= f.label :classroom_id, "Classroom", class: "form-label" %>
          <%= f.collection_select :classroom_id, @classrooms, :id, :name, { selected: @selected_classroom_id }, { class: "form-select", onchange: "this.form.submit()" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h2 class="h5 mb-3"><%= @selected_classroom&.name %> schedule</h2>
    <div class="table-responsive">
      <table class="table table-bordered table-sm" style="table-layout: fixed;">
        <thead>
          <tr>
            <th style="width: 80px;"></th>
            <% days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"] %>
            <% days.each do |day_name| %>
              <th><%= day_name %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% (7..22).each do |hour| %>
            <tr>
              <td class="fw-bold bg-light"><%= "%02d:00" % hour %></td>
              <% (1..6).each do |day| %>
                <% classes = @course_classes[[day, hour]] || [] %>
                <td class="p-1" style="min-width: 120px; position: relative; <%= classes.empty? ? 'cursor: pointer;' : '' %>" <%= raw('onclick="openModal(' + day.to_s + ', ' + hour.to_s + ')"') if classes.empty? %>>
                  <% if classes.any? %>
                    <% classes.each do |cc| %>
                      <% 
                        career = cc.teacher_subject.subject.careers.first
                        bg_color = career_palette[career&.name] || default_color
                        text_color = (career&.name == "Finance") ? "#000" : "#fff"
                      %>
                      <div class="badge d-block text-start position-relative pe-3 pb-2 mb-1" style="background-color: <%= bg_color %>; color: <%= text_color %>;" title="<%= cc.teacher_subject.subject.name %>">
                        <%= truncate(cc.teacher_subject.subject.name, length: 25) %><br>
                        <small style="opacity: 0.9;"><%= cc.teacher_subject.teacher.name %></small>
                        <%= button_to "×", admin_course_class_path(cc), method: :delete, class: "btn btn-sm position-absolute top-0 end-0 py-0 px-1 pb-1", style: "font-size: 20px; line-height: 0.75; color: #{text_color}; border: none; background: transparent; opacity: 0.7; font-weight: bold;" %>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="text-muted text-center">+</div>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal fade" id="courseClassModal" tabindex="-1" aria-labelledby="courseClassModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="courseClassModalLabel">Create Class</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with url: admin_course_classes_path, scope: :course_class do |f| %>
        <%= f.hidden_field :classroom_id, value: @selected_classroom_id %>
        <%= f.hidden_field :weekday, id: "modal_weekday" %>
        <%= f.hidden_field :dayhour, id: "modal_dayhour" %>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Day: <span id="modal_day_label"></span>, Hour: <span id="modal_hour_label"></span></label>
          </div>
          <div class="mb-3">
            <label for="modal_career_id" class="form-label">Career Filter (Optional)</label>
            <select id="modal_career_id" class="form-select" onchange="filterTeacherSubjects()">
              <option value="">All Careers</option>
              <% @careers.each do |career| %>
                <option value="<%= career.id %>"><%= career.name %></option>
              <% end %>
            </select>
          </div>
          <div class="mb-3">
            <%= f.label :teacher_subject_id, "Teacher - Subject", class: "form-label" %>
            <%= f.collection_select :teacher_subject_id, @teacher_subjects, :id, :display_name, { prompt: "Select teacher-subject" }, { class: "form-select", required: true, id: "modal_teacher_subject_id" } %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= f.submit "Create Class", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  let modal;

  function initModal() {
    if (typeof bootstrap !== 'undefined') {
      modal = new bootstrap.Modal(document.getElementById('courseClassModal'));
    } else {
      setTimeout(initModal, 50);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModal);
  } else {
    initModal();
  }

  const dayNames = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
  function openModal(day, hour) {
    document.getElementById('modal_weekday').value = day;
    document.getElementById('modal_dayhour').value = hour;
    document.getElementById('modal_day_label').textContent = dayNames[day - 1];
    document.getElementById('modal_hour_label').textContent = (hour < 10 ? '0' : '') + hour + ':00';
    if (modal) modal.show();
  }

  const careerTsMap = <%= raw @career_ts_map.to_json %>;

  function filterTeacherSubjects() {
    const careerId = document.getElementById('modal_career_id').value;
    const tsSelect = document.getElementById('modal_teacher_subject_id');
    const allowedIds = careerId ? careerTsMap[careerId] : null;

    Array.from(tsSelect.options).forEach(opt => {
      if (opt.value === "") return;
      const allowed = (!allowedIds || allowedIds.includes(parseInt(opt.value)));
      opt.hidden = !allowed;
      opt.disabled = !allowed;
    });
    tsSelect.value = "";
  }
</script>
