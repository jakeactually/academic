<% content_for :title, "Teachers" %>

<h1 class="h3 mb-4">Teachers</h1>
<p><%= link_to "Back to Dashboard", root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="h5">Create Teacher</h2>
    <%= form_with url: admin_teachers_path, scope: :teacher do |f| %>
      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true %>
      </div>
      <%= f.submit "Create Teacher", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white py-3 border-bottom">
    <h2 class="h5 mb-0">List</h2>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Name</th>
            <th>Email</th>
            <th class="text-end pe-4">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if @teachers.any? %>
            <% @teachers.each do |teacher| %>
              <tr>
                <td class="ps-4 fw-bold"><%= teacher.name %></td>
                <td><span class="text-muted"><%= teacher.email %></span></td>
                <td class="text-end pe-4">
                  <%= button_to "Delete", admin_teacher_path(teacher), method: :delete, class: "btn btn-outline-danger btn-sm", data: { turbo_confirm: "Are you sure?" } %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="text-center p-4 text-muted">No teachers found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
