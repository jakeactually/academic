<% content_for :title, "Career Subjects" %>

<h1 class="h3 mb-4">Career Subjects</h1>
<p><%= link_to "Back to Dashboard", root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <%= form_with url: admin_career_subjects_path, method: :get, data: { turbo_frame: "career_subjects_content", turbo_action: "advance" } do |f| %>
      <div class="row align-items-center g-3">
        <div class="col-auto">
          <%= f.label :career_id, "Select Career:", class: "form-label mb-0 fw-bold" %>
        </div>
        <div class="col-md-4">
          <%= f.collection_select :career_id, @careers, :id, :name, 
              { selected: params[:career_id], prompt: "Choose a career..." }, 
              { class: "form-select", onchange: "this.form.requestSubmit()" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "career_subjects_content" do %>
  <% if @career %>
    <div class="row g-4">
      <!-- Assigned Subjects (Left) -->
      <div class="col-md-6">
        <div class="card h-100 shadow-sm border-primary">
          <div class="card-header bg-primary text-white py-3">
            <h2 class="h5 mb-0">Assigned to <%= @career.name %></h2>
          </div>
          <div class="card-body p-0">
            <% if @career_subjects.any? %>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="ps-3" style="width: 100px;">Semester</th>
                      <th>Subject</th>
                      <th class="text-end pe-3">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @career_subjects.each do |item| %>
                      <tr>
                        <td class="ps-3"><span class="badge bg-secondary">Sem <%= item.semester %></span></td>
                        <td class="fw-bold"><%= item.subject.name %></td>
                        <td class="text-end pe-3">
                          <%= button_to "Remove", admin_career_subject_path(item, career_id: @career.id), 
                              method: :delete, 
                              class: "btn btn-outline-danger btn-sm",
                              data: { turbo_confirm: "Are you sure you want to remove this subject?" } %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <div class="p-5 text-center text-muted">
                <p class="mb-0">No subjects assigned to this career yet.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Available Subjects (Right) -->
      <div class="col-md-6">
        <div class="card h-100 shadow-sm border-success">
          <div class="card-header bg-success text-white py-3">
            <h2 class="h5 mb-0">Available Subjects</h2>
          </div>
          <div class="card-body p-0">
            <% if @available_subjects.any? %>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="ps-3">Subject</th>
                      <th style="width: 100px;">Semester</th>
                      <th class="text-end pe-3">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @available_subjects.each do |subject| %>
                      <tr>
                        <td class="ps-3 fw-bold"><%= subject.name %></td>
                        <td colspan="2">
                          <%= form_with model: [:admin, CareerSubject.new], class: "d-flex align-items-center gap-2 justify-content-end" do |f| %>
                            <%= f.hidden_field :career_id, value: @career.id %>
                            <%= f.hidden_field :subject_id, value: subject.id %>
                            <%= f.number_field :semester, value: 1, min: 1, class: "form-control form-control-sm", style: "width: 70px;", required: true %>
                            <%= f.submit "Add", class: "btn btn-outline-success btn-sm" %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <div class="p-5 text-center text-muted">
                <p class="mb-0">All subjects have been assigned to this career.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card shadow-sm">
      <div class="card-body py-5 text-center text-muted">
        <i class="bi bi-info-circle fs-2 mb-3 d-block"></i>
        <p class="h5 mb-1">No Career Selected</p>
        <p class="mb-0">Please choose a career from the dropdown above to manage its subjects.</p>
      </div>
    </div>
  <% end %>
<% end %>
