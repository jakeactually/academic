<% content_for :title, "Career Subjects" %>

<h1 class="h3 mb-4">Career Subjects</h1>
<p><%= link_to "Back to Admin", admin_root_path, class: "btn btn-outline-secondary btn-sm mb-3" %></p>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="h5">Assign Subject to Career</h2>
    <%= form_with url: admin_career_subjects_path, scope: :career_subject do |f| %>
      <div class="mb-3">
        <%= f.label :career_id, "Career", class: "form-label" %>
        <%= f.collection_select :career_id, @careers, :id, :name, { prompt: "Select career" }, { class: "form-select", required: true } %>
      </div>
      <div class="mb-3">
        <%= f.label :subject_id, "Subject", class: "form-label" %>
        <%= f.collection_select :subject_id, @subjects, :id, :name, { prompt: "Select subject" }, { class: "form-select", required: true } %>
      </div>
      <div class="mb-3">
        <%= f.label :semester, "Semester", class: "form-label" %>
        <%= f.number_field :semester, class: "form-control", required: true, min: 1, placeholder: "1" %>
      </div>
      <%= f.submit "Assign Subject", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h2 class="h5">List</h2>
    <ul class="mb-0">
      <% @career_subjects.each do |item| %>
        <li class="d-flex justify-content-between align-items-center gap-2">
          <span><%= item.career.name %> - Semester <%= item.semester %>: <%= item.subject.name %></span>
          <%= button_to "Delete", admin_career_subject_path(item), method: :delete, class: "btn btn-outline-danger btn-sm" %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
